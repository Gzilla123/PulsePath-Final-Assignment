<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@color/bg_card"
    android:layout_marginBottom="4dp" android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <View android:id="@+id/viewTypeStrip" android:layout_width="4dp" android:layout_height="48dp"
            android:layout_marginEnd="14dp" android:background="@color/purple_accent"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvWorkoutType" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Running"
                android:textColor="@color/navy" android:textSize="15sp"
                android:textStyle="bold" android:fontFamily="monospace"/>
            <TextView android:id="@+id/tvWorkoutDate" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary" android:textSize="12sp"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="8dp"
                android:gravity="center_vertical">
                <TextView android:id="@+id/tvDuration" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/purple_accent"
                    android:textSize="12sp" android:textStyle="bold" android:fontFamily="monospace"/>
                <View android:layout_width="4dp" android:layout_height="4dp"
                    android:layout_marginHorizontal="8dp" android:background="@color/text_dim"/>
                <TextView android:id="@+id/tvCaloriesItem" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/xp_green"
                    android:textSize="12sp" android:textStyle="bold" android:fontFamily="monospace"/>
                <View android:layout_width="4dp" android:layout_height="4dp"
                    android:layout_marginHorizontal="8dp" android:background="@color/text_dim"/>
                <TextView android:id="@+id/tvStepsItem" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                    android:textSize="12sp" android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
